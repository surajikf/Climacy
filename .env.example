# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: required for /api/admin/users (list/update/delete Auth users, purge)
SUPABASE_SERVICE_ROLE_KEY=

# Internal Invoice System (ASMX GetClients). App appends ?status=Y|N
# Overrides DB "Invoice API URL" in Settings only when DB value is empty.
# Use your real ASMX URL; app adds &status=Y or &status=N
INVOICE_API_URL=http://192.168.x.x/invoice/api/ApiService.asmx?op=GetClients
# Optional: sent as X-API-Key on each invoice fetch (omit if your endpoint is open on LAN)
INVOICE_API_KEY=
# Optional: if your API expects the key as a query param, set the param name (e.g. apikey). When set, X-API-Key is not sent.
# INVOICE_API_KEY_QUERY_NAME=apikey
