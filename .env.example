# --- DATABASE & CORE ---
# PostgreSQL Connection URL (Required for Prisma)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- SUPABASE (Public) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- SUPABASE (Private/Server-only) ---
# Required for /api/admin/users and administrative housekeeping.
SUPABASE_SERVICE_ROLE_KEY=

# --- ENCRYPTION & SECURITY ---
# A secure, random string used to encrypt sensitive keys (API keys, etc.) in the DB.
STRATEGIC_SECRET=change-this-to-a-secure-random-string

# --- GOOGLE OAUTH2 (Gmail Integration) ---
# Required for Google OAuth flow and campaign delivery.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI PROVIDERS (Optional Fallbacks) ---
# Can also be configured via the "Settings" page in the UI.
GROQ_API_KEY=
OPENAI_API_KEY=

# --- INTERNAL INTEGRATIONS ---
# Internal Invoice System (ASMX GetClients).
INVOICE_API_URL=http://localhost/invoice/api/ApiService.asmx
INVOICE_API_KEY=
# INVOICE_API_KEY_QUERY_NAME=apikey

# --- PRODUCTION SETTINGS ---
NODE_ENV=production
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional when hosting under an IIS virtual directory or subpath, e.g. /ikf-outreach
NEXT_PUBLIC_BASE_PATH=
